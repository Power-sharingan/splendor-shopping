<style>
.ist-section * { box-sizing: border-box; }
.ist-section {
  --ist-bg: #f3ece2;
  --ist-brown: #6b4f3a;
  --ist-accent: #a86a3d;
  --ist-text: #5a5550;
  --ist-line: #d9cfc4;
  position: relative;
  max-width: 520px;
  margin: 0 auto;
  padding: 34px 26px 28px;
  background: var(--ist-bg);
  border-radius: 18px;
  text-align: center;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  overflow: hidden;
}
.ist-title { margin: 0 0 6px; font-size: 34px; font-weight: 800; color: #2b2b2b; line-height: 1.15; }
.ist-arrow { position: absolute; top: 86px; right: 30%; width: 46px; height: 46px; opacity: .8; }
.ist-track { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scroll-behavior: smooth; scrollbar-width: none; }
.ist-track::-webkit-scrollbar { display: none; }
.ist-slide { flex: 0 0 100%; scroll-snap-align: center; padding: 6px 4px 0; display: flex; flex-direction: column; align-items: center; }
.ist-img { width: 100%; max-width: 230px; height: 175px; object-fit: contain; margin: 8px 0 14px; background: transparent; }
.ist-img.is-fallback { background: #e7ddd0; border-radius: 12px; }
.ist-name { margin: 0 0 12px; font-size: 19px; font-weight: 700; letter-spacing: 1px; color: var(--ist-brown); }
.ist-badge { display: inline-block; padding: 9px 20px; border: 1.5px solid var(--ist-brown); border-radius: 30px; font-size: 15px; font-weight: 700; color: #3a332c; background: #fff; margin-bottom: 16px; }
.ist-desc { margin: 0; max-width: 380px; font-size: 16px; line-height: 1.5; color: var(--ist-text); }
.ist-progress { display: flex; justify-content: center; gap: 8px; margin: 22px 0 18px; }
.ist-progress button { width: 34px; height: 5px; padding: 0; border: 0; border-radius: 3px; background: var(--ist-line); cursor: pointer; transition: background .25s; }
.ist-progress button.is-active { background: var(--ist-accent); }
.ist-controls { display: flex; justify-content: center; gap: 12px; }
.ist-btn { min-width: 120px; padding: 11px 18px; border: 1px solid var(--ist-line); border-radius: 30px; background: #fff; color: #3a332c; font-size: 15px; font-weight: 600; cursor: pointer; transition: background .2s, border-color .2s; }
.ist-btn:hover { background: #faf6f0; border-color: var(--ist-brown); }
.ist-btn:disabled { opacity: .4; cursor: default; }
@media (max-width: 480px) {
  .ist-title { font-size: 28px; }
  .ist-arrow { top: 72px; right: 26%; width: 40px; height: 40px; }
  .ist-img { height: 150px; }
}
</style>

<script>
(function () {
  /* =========================================================
     EDIT ONLY THIS LIST.
     Paste your Shopify/GemPages image URL into each "img".
     Add or remove items freely — the carousel adjusts itself.
     ========================================================= */
  var SLIDES = [
    {
      img:   "REPLACE_IMAGE_1",
      name:  "VITAMIN E",
      badge: "Protects Actively",
      desc:  "Protects against environmental stressors with its antioxidant properties, contributing to a vibrant, youthful look."
    },
    {
      img:   "REPLACE_IMAGE_2",
      name:  "HYALURONIC ACID",
      badge: "Hydrates Deeply",
      desc:  "Draws moisture into the skin for lasting hydration, leaving it plump, smooth, and visibly refreshed."
    },
    {
      img:   "REPLACE_IMAGE_3",
      name:  "NIACINAMIDE",
      badge: "Evens Tone",
      desc:  "Helps brighten and balance skin tone while supporting a healthy, even-looking complexion over time."
    },
    {
      img:   "REPLACE_IMAGE_4",
      name:  "SQUALANE",
      badge: "Smooths Softly",
      desc:  "A lightweight moisturizer that softens and conditions skin without a greasy feel, for a soft, supple finish."
    }
  ];
  /* ===================== end edit zone ===================== */

  var track = document.getElementById('istTrack');
  var progress = document.getElementById('istProgress');
  if (!track) return;
  var section = track.closest('.ist-section');
  var prev = section.querySelector('.ist-prev');
  var next = section.querySelector('.ist-next');

  // 1x1 transparent fallback so broken URLs don't show the broken-image icon
  var FALLBACK = "data:image/svg+xml;utf8," + encodeURIComponent(
    '<svg xmlns="http://www.w3.org/2000/svg" width="230" height="175"></svg>'
  );

  function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  // build slides
  SLIDES.forEach(function (s) {
    var slide = document.createElement('div');
    slide.className = 'ist-slide';
    var hasImg = s.img && s.img.indexOf('REPLACE_IMAGE') === -1;
    slide.innerHTML =
      '<img class="ist-img' + (hasImg ? '' : ' is-fallback') + '" ' +
        'src="' + (hasImg ? esc(s.img) : FALLBACK) + '" ' +
        'alt="' + esc(s.name) + '" ' +
        'onerror="this.onerror=null;this.classList.add(\'is-fallback\');this.src=\'' + FALLBACK + '\';">' +
      '<h3 class="ist-name">' + esc(s.name) + '</h3>' +
      '<div class="ist-badge">' + esc(s.badge) + '</div>' +
      '<p class="ist-desc">' + esc(s.desc) + '</p>';
    track.appendChild(slide);
  });

  var slides = track.querySelectorAll('.ist-slide');

  SLIDES.forEach(function (_, i) {
    var b = document.createElement('button');
    b.setAttribute('aria-label', 'Go to slide ' + (i + 1));
    b.addEventListener('click', function () { goTo(i); });
    progress.appendChild(b);
  });
  var segs = progress.querySelectorAll('button');

  function index() {
    return Math.max(0, Math.min(slides.length - 1, Math.round(track.scrollLeft / track.clientWidth)));
  }
  function goTo(i) { track.scrollTo({ left: i * track.clientWidth, behavior: 'smooth' }); }
  function update() {
    var idx = index();
    segs.forEach(function (s, i) { s.classList.toggle('is-active', i === idx); });
    prev.disabled = idx === 0;
    next.disabled = idx === slides.length - 1;
  }

  track.addEventListener('scroll', function () { window.requestAnimationFrame(update); });
  prev.addEventListener('click', function () { goTo(index() - 1); });
  next.addEventListener('click', function () { goTo(index() + 1); });
  window.addEventListener('resize', update);
  update();
})();
</script>
