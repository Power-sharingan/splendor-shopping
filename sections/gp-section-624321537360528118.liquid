<style>
.ca-section * { box-sizing: border-box; }
.ca-section {
  --ca-brown: #5b4034;
  --ca-text: #4a4a4a;
  --ca-border: #ece7e3;
  position: relative;
  max-width: 1080px;
  margin: 0 auto;
  padding: 10px 0 24px;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}
.ca-title { text-align: center; font-size: 30px; font-weight: 800; color: #2b2b2b; margin: 0 0 26px; line-height: 1.25; }
.ca-track { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
.ca-card { position: relative; background: #fff; border: 1px solid var(--ca-border); border-radius: 18px; box-shadow: 0 8px 24px rgba(0,0,0,.06); overflow: hidden; }
.ca-head { background: var(--ca-brown); color: #fff; padding: 16px 18px 14px; min-height: 76px; }
.ca-name { margin: 0; font-size: 19px; font-weight: 800; line-height: 1.15; }
.ca-role { margin: 6px 0 0; font-size: 13px; font-weight: 500; display: flex; align-items: center; gap: 6px; }
.ca-badge { display: inline-flex; align-items: center; justify-content: center; width: 16px; height: 16px; border-radius: 50%; background: #fff; color: var(--ca-brown); font-size: 10px; font-weight: 900; flex: 0 0 auto; }
.ca-body { padding: 16px 18px 18px; }
.ca-quote { margin: 0; font-style: italic; font-size: 15px; line-height: 1.5; color: var(--ca-text); max-width: 70%; min-height: 92px; }
.ca-photo { position: absolute; right: 0; bottom: 0; width: 34%; max-width: 150px; height: auto; object-fit: contain; pointer-events: none; }
.ca-photo.is-fallback { width: 110px; height: 110px; background: #efe9e4; border-top-left-radius: 14px; }
.ca-arrow { position: absolute; top: 50%; transform: translateY(-50%); z-index: 3; width: 40px; height: 40px; border-radius: 50%; border: 1px solid var(--ca-border); background: #fff; color: var(--ca-brown); font-size: 22px; line-height: 1; cursor: pointer; box-shadow: 0 4px 12px rgba(0,0,0,.1); display: none; }
.ca-prev { left: -6px; }
.ca-next { right: -6px; }
.ca-dots { display: none; justify-content: center; gap: 8px; margin-top: 16px; }
.ca-dots button { width: 8px; height: 8px; padding: 0; border: 0; border-radius: 50%; background: #cfc5be; cursor: pointer; transition: .2s; }
.ca-dots button.is-active { background: var(--ca-brown); width: 22px; border-radius: 5px; }

@media (max-width: 768px) {
  .ca-title { font-size: 24px; margin-bottom: 20px; }
  .ca-track { display: flex; grid-template-columns: none; gap: 14px; overflow-x: auto; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scroll-behavior: smooth; padding: 4px 16px; scrollbar-width: none; }
  .ca-track::-webkit-scrollbar { display: none; }
  .ca-card { flex: 0 0 86%; scroll-snap-align: center; }
  .ca-quote { font-size: 14px; max-width: 70%; }
  .ca-arrow { display: flex; align-items: center; justify-content: center; }
  .ca-prev { left: 4px; }
  .ca-next { right: 4px; }
  .ca-dots { display: flex; }
}
</style>

<script>
(function () {
  /* =========================================================
     EDIT ONLY THIS LIST.
     Paste each celebrity image URL into "img".
     Add or remove cards freely — the slider adjusts itself.
     ========================================================= */
  var CARDS = [
    {
      img:   "REPLACE_IMAGE_1",
      name:  "Halle Berry",
      role:  "Actress & Producer",
      quote: "Most brands don\u2019t get our skin. Splendor Balm does."
    },
    {
      img:   "REPLACE_IMAGE_2",
      name:  "Dr. Sharon Martinez, MD",
      role:  "Board-Certified Dermatologist",
      quote: "What I love about Splendor Balm is that it blends like skincare but wears like makeup \u2014 plus, it\u2019s specifically formulated for melanin-rich skin."
    },
    {
      img:   "REPLACE_IMAGE_3",
      name:  "Janet Jackson",
      role:  "Singer & Cultural Icon",
      quote: "It\u2019s my go-to when I want to feel fresh and confident without doing too much."
    }
  ];
  /* ===================== end edit zone ===================== */

  var track = document.getElementById('caTrack');
  var dotsWrap = document.getElementById('caDots');
  if (!track) return;
  var section = track.closest('.ca-section');
  var prev = section.querySelector('.ca-prev');
  var next = section.querySelector('.ca-next');

  var FALLBACK = "data:image/svg+xml;utf8," + encodeURIComponent(
    '<svg xmlns="http://www.w3.org/2000/svg" width="150" height="150"></svg>'
  );

  function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  CARDS.forEach(function (c) {
    var hasImg = c.img && c.img.indexOf('REPLACE_IMAGE') === -1;
    var card = document.createElement('div');
    card.className = 'ca-card';
    card.innerHTML =
      '<div class="ca-head">' +
        '<h3 class="ca-name">' + esc(c.name) + '</h3>' +
        '<p class="ca-role"><span class="ca-badge">&#10003;</span> ' + esc(c.role) + '</p>' +
      '</div>' +
      '<div class="ca-body">' +
        '<blockquote class="ca-quote">&ldquo;' + esc(c.quote) + '&rdquo;</blockquote>' +
      '</div>' +
      '<img class="ca-photo' + (hasImg ? '' : ' is-fallback') + '" ' +
        'src="' + (hasImg ? esc(c.img) : FALLBACK) + '" ' +
        'alt="' + esc(c.name) + '" ' +
        'onerror="this.onerror=null;this.classList.add(\'is-fallback\');this.removeAttribute(\'alt\');this.src=\'' + FALLBACK + '\';">';
    track.appendChild(card);
  });

  var cards = track.querySelectorAll('.ca-card');

  cards.forEach(function (_, i) {
    var b = document.createElement('button');
    b.setAttribute('aria-label', 'Go to slide ' + (i + 1));
    b.addEventListener('click', function () { scrollToCard(i); });
    dotsWrap.appendChild(b);
  });
  var dots = dotsWrap.querySelectorAll('button');

  function currentIndex() {
    var w = cards[0].offsetWidth + 14;
    return Math.max(0, Math.min(cards.length - 1, Math.round(track.scrollLeft / w)));
  }
  function scrollToCard(i) {
    var card = cards[i];
    track.scrollTo({ left: card.offsetLeft - (track.clientWidth - card.offsetWidth) / 2, behavior: 'smooth' });
  }
  function updateDots() {
    var idx = currentIndex();
    dots.forEach(function (d, i) { d.classList.toggle('is-active', i === idx); });
  }

  track.addEventListener('scroll', function () { window.requestAnimationFrame(updateDots); });
  prev.addEventListener('click', function () { scrollToCard(Math.max(0, currentIndex() - 1)); });
  next.addEventListener('click', function () { scrollToCard(Math.min(cards.length - 1, currentIndex() + 1)); });
  updateDots();
})();
</script>
